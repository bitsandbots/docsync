      - "__pycache__/**"
      - ".pytest_cache/**"
      - "venv/**"
      - "*.egg-info/**"
    category: "Tools"
    icon: "folder"
    backup:
      enabled: true
      include_all: true
      exclude:
        - ".git/**"
        - "__pycache__/**"
        - ".pytest_cache/**"
        - "venv/**"
        - "*.egg-info/**"
