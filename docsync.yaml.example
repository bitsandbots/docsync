      - "*.md"
    exclude:
      - ".git/**"
      - "__pycache__/**"
      - ".pytest_cache/**"
      - "venv/**"
      - "*.egg-info/**"
    category: "Tools"
    icon: "server"
    backup:
      enabled: true
      include_all: true
      exclude:
        - ".git/**"
        - "__pycache__/**"
        - ".pytest_cache/**"
        - "venv/**"
        - "*.egg-info/**"
      priority: "normal"

  - name: "TechLounge Review"
    type: local
    path: "/home/user/projects/techlounge-review-plan"
    include:
      - "README.md"
      - "*.md"
    exclude:
      - ".git/**"
    category: "Projects"
    icon: "document"
    backup:
      enabled: true
      include_all: true
      exclude:
        - ".git/**"
      priority: "low"

  - name: "Reference App"
    type: local
    path: "/home/user/projects/coreconduit-reference-app"
    include:
      - "README.md"
      - "docs/**/*.md"
      - "CLAUDE.md"
    exclude:
      - ".git/**"
      - "node_modules/**"
      - "__pycache__/**"
    category: "Applications"
    icon: "app"
    backup:
      enabled: true
      include_all: true
      exclude:
        - ".git/**"
        - "node_modules/**"
        - "__pycache__/**"
      priority: "normal"

  - name: "UI Kit"
    type: local
    path: "/home/user/projects/coreconduit-ui-kit"
    include:
      - "README.md"
      - "docs/**/*.md"
    exclude:
      - ".git/**"
      - "node_modules/**"
      - "__pycache__/**"
    category: "Tools"
    icon: "palette"
    backup:
      enabled: true
      include_all: true
      exclude:
        - ".git/**"
        - "node_modules/**"
        - "__pycache__/**"
      priority: "normal"

  - name: "Frontend Migration"
    type: local
    path: "/home/user/projects/coreconduit-frontend-migration"
    include:
      - "README.md"
      - "docs/**/*.md"
      - "CLAUDE.md"
    exclude:
      - ".git/**"
      - "node_modules/**"
      - "__pycache__/**"
    category: "Development"
    icon: "code"
    backup:
      enabled: true
      include_all: true
      exclude:
        - ".git/**"
        - "node_modules/**"
        - "__pycache__/**"
      priority: "normal"

  - name: "MCP Memory Service"
    type: local
    path: "/home/user/projects/mcp-memory-service"
    include:
      - "README.md"
      - "docs/**/*.md"
      - "*.py"
    exclude:
      - ".git/**"
      - "node_modules/**"
      - "__pycache__/**"
      - "venv/**"
    category: "Services"
    icon: "database"
    backup:
      enabled: true
      include_all: true
      exclude:
        - ".git/**"
        - "node_modules/**"
        - "__pycache__/**"
        - "venv/**"
