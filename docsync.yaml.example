# ~/.config/docsync/docsync.yaml
# DocSync configuration — copy to ~/.config/docsync/docsync.yaml and edit.

site:
  title: "CoreConduit Reference Wiki"
  output_dir: "/var/www/docsync"
  base_url: "http://localhost:8484"
  theme: "coreconduit"

sync:
  schedule: "0 */4 * * *"        # every 4 hours
  on_change: true
  log_file: "/var/log/docsync/sync.log"

# ── Backup Configuration ──────────────────────────────────
backup:
  enabled: true
  base_dir: "/mnt/backups/docsync"
  schedule: "0 2 * * *"          # nightly at 2 AM
  strategy: "incremental"        # incremental | full
  retention:
    daily: 7
    weekly: 4
    monthly: 6
  compression: "zstd"            # zstd | gzip | none
  verify_after_backup: true
  max_total_size_gb: 50
  notifications:
    on_failure: true
    on_success: false
    webhook_url: ""              # optional: ntfy/Gotify URL

sources:
  # ── Primary Projects ───────────────────────────────────
  - name: "Inventory System"
    type: local
    path: "/home/user/projects/inventory"
    include:
      - "docs/**/*.md"
      - "README.md"
    exclude:
      - "vendor/**"
      - "node_modules/**"
      - ".git/**"
    category: "Applications"
    icon: "database"
    backup:
      enabled: true
      include_all: false
      include:
        - "docs/**"
        - "src/**/*.php"
        - "config/**"
      exclude:
        - "vendor/**"
        - "node_modules/**"
        - ".git/**"
      priority: "high"

  - name: "RPI Monitor"
    type: local
    path: "/home/user/projects/rpi-monitor"
    include:
      - "docs/**/*.md"
      - "README.md"
    exclude:
      - "node_modules/**"
      - ".git/**"
    category: "Tools"
    icon: "server"
    backup:
      enabled: true
      include_all: true
      exclude:
        - "node_modules/**"
        - ".git/**"
        - "__pycache__/**"
      priority: "normal"

  - name: "RPI Sync"
    type: local
    path: "/home/user/projects/rpi-sync"
    include:
      - "docs/**/*.md"
      - "README.md"
    exclude:
      - ".git/**"
    category: "Tools"
    icon: "sync"
    backup:
      enabled: true
      include_all: true
      exclude:
        - ".git/**"
        - "__pycache__/**"
      priority: "normal"

  - name: "DocSync"
    type: local
    path: "/home/user/projects/docsync"
    include:
      - "docs/**/*.md"
      - "README.md"
    exclude:
      - ".git/**"
    category: "Tools"
    icon: "book"
    backup:
      enabled: true
      include_all: true
      exclude:
        - ".git/**"
        - "__pycache__/**"
        - ".pytest_cache/**"
        - "*.egg-info/**"
      priority: "normal"

  - name: "Flow Analyzer"
    type: local
    path: "/home/user/projects/flow-analyzer"
    include:
      - "docs/**/*.md"
      - "README.md"
    exclude:
      - ".git/**"
      - "node_modules/**"
    category: "Tools"
    icon: "chart"
    backup:
      enabled: true
      include_all: true
      exclude:
        - ".git/**"
        - "node_modules/**"
      priority: "normal"

  - name: "RAG Chatbot"
    type: local
    path: "/home/user/projects/rag-chatbot"
    include:
      - "docs/**/*.md"
      - "README.md"
    exclude:
      - ".git/**"
      - "node_modules/**"
    category: "Applications"
    icon: "message"
    backup:
      enabled: true
      include_all: true
      exclude:
        - ".git/**"
        - "node_modules/**"
      priority: "normal"

  - name: "Inventory Test Harness"
    type: local
    path: "/home/user/projects/inventory-test-harness"
    include:
      - "docs/**/*.md"
      - "README.md"
    exclude:
      - ".git/**"
    category: "Testing"
    icon: "flask"
    backup:
      enabled: true
      include_all: true
      exclude:
        - ".git/**"
        - "__pycache__/**"
      priority: "low"

  - name: "Claude Configuration"
    type: local
    path: "/home/user/projects/coreconduit-claude-harness"
    include:
      - "docs/**/*.md"
      - "README.md"
      - "**/*.md"
    exclude:
      - ".git/**"
    category: "Tools"
    icon: "terminal"
    backup:
      enabled: true
      include_all: true
      exclude:
        - ".git/**"
        - "node_modules/**"
      priority: "normal"

  - name: "Claude Backups"
    type: local
    path: "/home/user/projects/.claude-backups"
    include:
      - "**/*.md"
    exclude:
      - ".git/**"
    category: "Configuration"
    icon: "folder"
    backup:
      enabled: true
      include_all: true
      exclude:
        - ".git/**"
      priority: "low"

  - name: "Code Review"
    type: local
    path: "/home/user/projects/codereview"
    include:
      - "docs/**/*.md"
      - "README.md"
      - "CLAUDE.md"
      - "*.md"
    exclude:
      - ".git/**"
      - "node_modules/**"
      - "__pycache__/**"
      - ".pytest_cache/**"
    category: "Tools"
    icon: "code"
    backup:
      enabled: true
      include_all: true
      exclude:
        - ".git/**"
        - "node_modules/**"
        - "__pycache__/**"
        - ".pytest_cache/**"
        - "dist/**"
      priority: "normal"

  - name: "RPI Clippy"
    type: local
    path: "/home/user/projects/rpi-clippy"
    include:
      - "README.md"
      - "CLAUDE.md"
      - "LICENSE.md"
    exclude:
      - ".git/**"
      - "node_modules/**"
    category: "Applications"
    icon: "clipboard"
    backup:
      enabled: true
      include_all: false
      include:
        - "*.py"
        - "*.md"
        - "assets/**"
      exclude:
        - ".git/**"
        - "node_modules/**"
        - "*.txt"
        - "session-*.md"
      priority: "normal"

  - name: "SiteEdit"
    type: local
    path: "/home/user/projects/siteedit"
