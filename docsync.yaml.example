    exclude:
      - ".git/**"
      - "node_modules/**"
      - "__pycache__/**"
      - ".pytest_cache/**"
      - "session-*.md"
    category: "Tools"
    icon: "edit"
    backup:
      enabled: true
      include_all: true
      exclude:
        - ".git/**"
        - "node_modules/**"
        - "__pycache__/**"
        - ".pytest_cache/**"
        - "session-*.md"
      priority: "normal"

  - name: "FileForge"
    type: local
    path: "/home/user/projects/fileforge"
